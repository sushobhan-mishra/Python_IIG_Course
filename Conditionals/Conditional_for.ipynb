   "source": [
    "j = int(input('Enter a number for range to print even number:'))\n",
    "for i in range(1 , j+1):\n",
    "    if i % 2 == 0:\n",
    "        print(f'{i} is even')\n",
    "    else:\n",
    "        print(f'{i} is odd')"
   ]
