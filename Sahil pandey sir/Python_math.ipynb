    "# Example 1\n",
    "import math\n",
    "x  = 6.5\n",
    "y1 = math.ceil(x)\n",
    "print(y1)\n",
    "\n",
    "y2 = math.floor(x)\n",
    "print(y2)\n",
    "\n",
    "y3 = math.fabs(-0.5)\n",
    "print(y3)\n",
    "\n",
    "y4 = math.factorial(7)\n",
    "print(y4)\n",
    "\n",
    "y5 = math.fmod(5,1.5)\n",
    "print(y5)"
